@using Shared.Contracts.Auth
@using Client.Services
@inject II18nService I18n

<EditForm Model="@ResetPasswordRequest" OnValidSubmit="@HandleSubmit">
    <LocalizedDataAnnotationsValidator />

    <MudTextField @bind-Value="ResetPasswordRequest.NewPassword" For="@(() => ResetPasswordRequest.NewPassword)"
        Label="@I18n.GetCommon("newPassword")" HelperText="@I18n.GetHelpText("resetPasswordNewPassword")"
        Variant="Variant.Outlined" InputType="@newPasswordInput" Immediate="true" Required="true" Class="mb-3"
        Adornment="Adornment.End" AdornmentIcon="@newPasswordInputIcon" OnAdornmentClick="ToggleNewPasswordVisibility"
        AdornmentAriaLabel="@I18n.GetCommon("showPassword")" />

    <MudTextField @bind-Value="ResetPasswordRequest.ConfirmPassword" For="@(() => ResetPasswordRequest.ConfirmPassword)"
        Label="@I18n.GetCommon("confirmPassword")" Variant="Variant.Outlined" InputType="@confirmPasswordInput"
        Immediate="true" Required="true" Class="mb-3" Adornment="Adornment.End"
        AdornmentIcon="@confirmPasswordInputIcon" OnAdornmentClick="ToggleConfirmPasswordVisibility"
        AdornmentAriaLabel="@I18n.GetCommon("showPassword")" />

    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
        Disabled="@IsLoading" Class="mt-3 rounded-pill">
        <Spinner IsLoading="@IsLoading" LoadingText="@I18n.GetCommon("updating")"
            DefaultText="@I18n.GetCommon("resetPassword")" />
    </MudButton>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public ResetPasswordRequest ResetPasswordRequest { get; set; } = new();

    [Parameter]
    public bool IsLoading { get; set; }

    [Parameter]
    public EventCallback<ResetPasswordRequest> OnSubmit { get; set; }

    private bool isNewPasswordVisible;
    private InputType newPasswordInput = InputType.Password;
    private string newPasswordInputIcon = Icons.Material.Filled.VisibilityOff;

    private bool isConfirmPasswordVisible;
    private InputType confirmPasswordInput = InputType.Password;
    private string confirmPasswordInputIcon = Icons.Material.Filled.VisibilityOff;

    private void ToggleNewPasswordVisibility()
    {
        if (isNewPasswordVisible)
        {
            isNewPasswordVisible = false;
            newPasswordInputIcon = Icons.Material.Filled.VisibilityOff;
            newPasswordInput = InputType.Password;
        }
        else
        {
            isNewPasswordVisible = true;
            newPasswordInputIcon = Icons.Material.Filled.Visibility;
            newPasswordInput = InputType.Text;
        }
    }

    private void ToggleConfirmPasswordVisibility()
    {
        if (isConfirmPasswordVisible)
        {
            isConfirmPasswordVisible = false;
            confirmPasswordInputIcon = Icons.Material.Filled.VisibilityOff;
            confirmPasswordInput = InputType.Password;
        }
        else
        {
            isConfirmPasswordVisible = true;
            confirmPasswordInputIcon = Icons.Material.Filled.Visibility;
            confirmPasswordInput = InputType.Text;
        }
    }

    private async Task HandleSubmit()
    {
        await OnSubmit.InvokeAsync(ResetPasswordRequest);
    }
}