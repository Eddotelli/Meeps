@using Shared.Contracts.Auth
@using Client.Services
@inject II18nService I18n

<EditForm Model="@ForgotPasswordRequest" OnValidSubmit="@HandleSubmit">
    <LocalizedDataAnnotationsValidator />

    <MudText Typo="Typo.body2" Class="mb-4">
        @I18n.GetMessage("passwordResetInstructions")
    </MudText>

    <MudTextField @bind-Value="ForgotPasswordRequest.Email" For="@(() => ForgotPasswordRequest.Email)"
        Label="@I18n.GetCommon("email")" HelperText="@I18n.GetHelpText("forgotPasswordEmail")"
        Variant="Variant.Outlined" InputType="InputType.Email" Immediate="true" Required="true" Class="mb-3" />

    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
        Disabled="@IsLoading" Class="mt-3 rounded-pill">
        <Spinner IsLoading="@IsLoading" LoadingText="@I18n.GetCommon("sending")"
            DefaultText="@I18n.GetCommon("sendResetLink")" />
    </MudButton>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public ForgotPasswordRequest ForgotPasswordRequest { get; set; } = new();

    [Parameter]
    public bool IsLoading { get; set; }

    [Parameter]
    public EventCallback<ForgotPasswordRequest> OnSubmit { get; set; }

    private async Task HandleSubmit()
    {
        await OnSubmit.InvokeAsync(ForgotPasswordRequest);
    }
}