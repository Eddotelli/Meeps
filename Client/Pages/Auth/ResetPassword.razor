@page "/reset-password"
@layout AuthLayout
@using Shared.Contracts.Auth
@using Shared.Common.Constants
@using Client.Components.Auth
@using Client.Components.Common
@using Client.Services.ApiClients
@using Client.Services
@implements IDisposable
@inject IAuthApiClient AuthApiClient
@inject NavigationManager Navigation
@inject II18nService I18n
@inject ILogger<ResetPassword> Logger

<PageTitle>@I18n.GetCommon("resetPassword")</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-4">
    <MudCard Elevation="0" Class="modern-section-card">
        <MudCardContent>
            <div class="modern-section-header">
                <div class="section-title-wrapper">
                    <MudText Typo="Typo.h6" Class="section-title">@I18n.GetCommon("resetYourPassword")</MudText>
                    <div class="title-accent"></div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(successMessageKey))
            {
                <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Class="mb-4">
                    @I18n.GetMessage(successMessageKey)
                </MudAlert>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/login" FullWidth="true"
                    Class="mt-3 rounded-pill" StartIcon="@Icons.Material.Filled.Login">
                    @I18n.GetCommon("backToLogin")
                </MudButton>
            }
            else if (string.IsNullOrEmpty(token))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-4">
                    @I18n.GetError(ErrorCodes.EmailInvalidLink)
                </MudAlert>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/forgot-password" FullWidth="true"
                    Class="mt-3 rounded-pill" StartIcon="@Icons.Material.Filled.Email">
                    @I18n.GetCommon("forgotPassword")
                </MudButton>
            }
            else
            {
                @if (!string.IsNullOrEmpty(errorCode))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4">@I18n.GetError(errorCode)</MudAlert>
                }

                <MudText Typo="Typo.body2" Class="mb-3">
                    @I18n.GetMessage("resetPasswordDescription")
                </MudText>

                <ResetPasswordForm ResetPasswordRequest="@resetPasswordRequest" IsLoading="@isLoading"
                    OnSubmit="@HandleSubmit" />

                <MudDivider Class="my-4" />

                <MudStack AlignItems="AlignItems.Center">
                    <MudLink Href="/login" Typo="Typo.body2" Color="Color.Primary">
                        @I18n.GetCommon("backToLogin")
                    </MudLink>
                </MudStack>
            }
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    private ResetPasswordRequest resetPasswordRequest = new();
    private string? token;
    private string? errorCode;
    private string? successMessageKey;
    private bool isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        I18n.OnLanguageChanged += StateHasChanged;

        // Get token from query string
        var uri = new Uri(Navigation.Uri);

        // Parse query string properly to handle Base64 URL-encoded tokens
        if (!string.IsNullOrEmpty(uri.Query))
        {
            var query = uri.Query.TrimStart('?');
            var parameters = query.Split('&');

            foreach (var param in parameters)
            {
                var parts = param.Split('=', 2); // Limit to 2 parts to handle = in token
                if (parts.Length == 2 && parts[0] == "token")
                {
                    // URL-decode the token (handles Base64 special chars)
                    token = Uri.UnescapeDataString(parts[1]);
                    resetPasswordRequest.Token = token;
                    Logger.LogInformation("Reset password page loaded with token length: {Length}", token.Length);
                    break;
                }
            }
        }

        if (string.IsNullOrEmpty(token))
        {
            Logger.LogWarning("Reset password page loaded without token");
            return;
        }

        // Validate token immediately on page load
        Logger.LogInformation("Validating reset token on page load");
        isLoading = true;

        var validateRequest = new ValidateResetTokenRequest { Token = token };
        var validateResult = await AuthApiClient.ValidateResetTokenAsync(validateRequest);

        if (validateResult.IsFailure)
        {
            Logger.LogError("Failed to validate reset token: {ErrorCode}", validateResult.Error?.Code);
            errorCode = validateResult.Error?.Code ?? ErrorCodes.ServerError;
            token = null; // Clear token to show error state
            isLoading = false;
            return;
        }

        if (!validateResult.Value!.IsValid)
        {
            Logger.LogWarning("Reset token is invalid or expired: {ErrorCode}", validateResult.Value.ErrorCode);
            errorCode = validateResult.Value.ErrorCode ?? ErrorCodes.UserPasswordResetTokenInvalid;
            token = null; // Clear token to show error state
            isLoading = false;
            return;
        }

        Logger.LogInformation("Reset token validated successfully");
        isLoading = false;
    }

    public void Dispose()
    {
        I18n.OnLanguageChanged -= StateHasChanged;
    }

    private async Task HandleSubmit(ResetPasswordRequest request)
    {
        isLoading = true;
        errorCode = null;
        successMessageKey = null;

        Logger.LogInformation("Attempting to reset password with token");

        var result = await AuthApiClient.ResetPasswordAsync(request);

        if (result.IsFailure)
        {
            Logger.LogWarning("Password reset failed. Error: {ErrorCode}", result.Error?.Code);
            errorCode = result.Error?.Code ?? ErrorCodes.ServerError;
            isLoading = false;
            return;
        }

        Logger.LogInformation("Password reset successful");
        successMessageKey = MessageKeys.PasswordResetSuccess;
        isLoading = false;
    }
}