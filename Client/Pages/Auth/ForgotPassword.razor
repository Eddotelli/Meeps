@page "/forgot-password"
@layout AuthLayout
@using Shared.Contracts.Auth
@using Shared.Common.Constants
@using Client.Components.Auth
@using Client.Components.Common
@using Client.Services.ApiClients
@using Client.Services
@implements IDisposable
@inject IAuthApiClient AuthApiClient
@inject NavigationManager Navigation
@inject II18nService I18n
@inject ILogger<ForgotPassword> Logger

<PageTitle>@I18n.GetCommon("forgotPassword")</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-4">
    <MudCard Elevation="0" Class="modern-section-card">
        <MudCardContent>
            <div class="modern-section-header">
                <div class="section-title-wrapper">
                    <MudText Typo="Typo.h6" Class="section-title">@I18n.GetCommon("forgotPassword")</MudText>
                    <div class="title-accent"></div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(successMessageKey))
            {
                <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Class="mb-4">
                    @I18n.GetMessage(successMessageKey)
                </MudAlert>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/login" FullWidth="true"
                    Class="mt-3 rounded-pill" StartIcon="@Icons.Material.Filled.ArrowBack">
                    @I18n.GetCommon("backToLogin")
                </MudButton>
            }
            else
            {
                @if (!string.IsNullOrEmpty(errorCode))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4">@I18n.GetError(errorCode)</MudAlert>
                }

                <ForgotPasswordForm ForgotPasswordRequest="@forgotPasswordRequest" IsLoading="@isLoading"
                    OnSubmit="@HandleSubmit" />

                <MudDivider Class="my-4" />

                <MudStack AlignItems="AlignItems.Center">
                    <MudLink Href="/login" Typo="Typo.body2" Color="Color.Primary">
                        @I18n.GetCommon("backToLogin")
                    </MudLink>
                </MudStack>
            }
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    private ForgotPasswordRequest forgotPasswordRequest = new();
    private string? errorCode;
    private string? successMessageKey;
    private bool isLoading = false;

    protected override void OnInitialized()
    {
        I18n.OnLanguageChanged += StateHasChanged;
    }

    public void Dispose()
    {
        I18n.OnLanguageChanged -= StateHasChanged;
    }

    private async Task HandleSubmit(ForgotPasswordRequest request)
    {
        isLoading = true;
        errorCode = null;
        successMessageKey = null;

        Logger.LogInformation("Password reset requested for email: {Email}", request.Email);

        var result = await AuthApiClient.ForgotPasswordAsync(request);

        if (result.IsFailure)
        {
            Logger.LogWarning("Forgot password failed for email: {Email}. Error: {ErrorCode}",
            request.Email, result.Error?.Code);
            errorCode = result.Error?.Code ?? ErrorCodes.ServerError;
            isLoading = false;
            return;
        }

        Logger.LogInformation("Password reset email sent for: {Email}", request.Email);
        successMessageKey = MessageKeys.PasswordResetEmailSent;
        isLoading = false;
    }
}