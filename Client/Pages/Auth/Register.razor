@page "/register"
@layout AuthLayout
@using Shared.Contracts.Auth
@using Shared.Common.Constants
@using Client.Components.Auth
@using Client.Components.Common
@using Client.Services.ApiClients
@using Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@implements IDisposable
@inject IAuthApiClient AuthApiClient
@inject NavigationManager Navigation
@inject II18nService I18n
@inject ILogger<Register> Logger
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>@I18n.GetCommon("register")</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-4">
    <MudCard Elevation="0" Class="modern-section-card">
        <MudCardContent>
            <div class="modern-section-header">
                <div class="section-title-wrapper">
                    <MudText Typo="Typo.h6" Class="section-title">@I18n.GetCommon("register")</MudText>
                    <div class="title-accent"></div>
                </div>
            </div>

            @if (!isEmailSent)
            {
                @if (!string.IsNullOrEmpty(errorCode))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4">@I18n.GetError(errorCode)</MudAlert>
                }

                <RegisterForm RegisterRequest="@registerRequest" IsLoading="@isLoading" OnSubmit="@HandleRegister" />

                <MudDivider Class="my-4" />

                <MudText Typo="Typo.body2" Align="Align.Center">
                    @I18n.GetCommon("alreadyHaveAccount")
                    <MudLink Href="/login" Color="Color.Primary">@I18n.GetCommon("loginHere")</MudLink>
                </MudText>
            }
            else
            {
                <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Class="mb-4">
                    @I18n.GetMessage(successMessageKey!)
                </MudAlert>
            }
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    private RegisterRequest registerRequest = new();
    private string? errorCode;
    private string? successMessageKey;
    private bool isLoading = false;
    private bool isEmailSent = false;

    protected override void OnInitialized()
    {
        I18n.OnLanguageChanged += StateHasChanged;
    }

    public void Dispose()
    {
        I18n.OnLanguageChanged -= StateHasChanged;
    }

    private async Task HandleRegister(RegisterRequest request)
    {
        isLoading = true;
        errorCode = null;
        successMessageKey = null;

        Logger.LogInformation("User attempting to register with email: {Email}", registerRequest.Email);

        var result = await AuthApiClient.RegisterAsync(registerRequest);

        if (result.IsFailure)
        {
            Logger.LogWarning("Registration failed for email: {Email}. Error: {ErrorCode}", registerRequest.Email,
            result.Error?.Code);
            errorCode = result.Error?.Code ?? ErrorCodes.ServerError;
            isLoading = false;
            return;
        }

        Logger.LogInformation("Registration successful for email: {Email}", registerRequest.Email);
        isEmailSent = true;
        successMessageKey = MessageKeys.EmailVerificationSent;
        isLoading = false;
    }
}