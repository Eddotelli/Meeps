{
  "info": {
    "name": "Meeps API",
    "description": "API tests for Meeps application - Social platform for organizing events",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "0. Reset Test User (Optional)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200 or 404\", function () {",
                  "    pm.expect([200, 404]).to.include(pm.response.code);",
                  "});",
                  "",
                  "console.log(\"Test user reset completed\");"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/test/reset-user/{{testEmail}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "test", "reset-user", "{{testEmail}}"]
            },
            "description": "Step 0 (Optional): Delete test user before starting fresh. Only available in DEBUG builds."
          },
          "response": []
        },
        {
          "name": "1. Register - Send Verification Email",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has message\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.exist;",
                  "    console.log(\"Message: \" + jsonData.message);",
                  "});",
                  "",
                  "pm.test(\"Response time is less than 1000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Step 1: Register with email. A verification link will be sent to the email address."
          },
          "response": []
        },
        {
          "name": "2. Get Verification Token (Auto)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has token\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.token).to.exist;",
                  "    pm.environment.set(\"verificationToken\", jsonData.token);",
                  "    console.log(\"Verification token saved: \" + jsonData.token);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/test/verification-token/{{testEmail}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "test", "verification-token", "{{testEmail}}"]
            },
            "description": "Step 2: Automatically get verification token from test endpoint. Only available in DEBUG builds."
          },
          "response": []
        },
        {
          "name": "3. Verify Email",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has message\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.exist;",
                  "    console.log(\"Verification Message: \" + jsonData.message);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{verificationToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/verify-email",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "verify-email"]
            },
            "description": "Step 3: Verify email using the token. This is required before completing registration."
          },
          "response": []
        },
        {
          "name": "4. Complete Registration",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has user ID\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.userId).to.exist;",
                  "});",
                  "",
                  "pm.test(\"Response has correct email\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.email).to.eql(pm.environment.get(\"testEmail\"));",
                  "});",
                  "",
                  "pm.test(\"Response has display name\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.displayName).to.exist;",
                  "});",
                  "",
                  "pm.test(\"Refresh token cookie is set\", function () {",
                  "    pm.expect(pm.cookies.has('refreshToken')).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"verificationToken\": \"{{verificationToken}}\",\n  \"displayName\": \"{{testDisplayName}}\",\n  \"fullName\": \"{{testFullName}}\",\n  \"password\": \"{{testPassword}}\",\n  \"birthYear\": {{testBirthYear}},\n  \"gender\": \"Other\",\n  \"categoryIds\": []\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/complete-registration",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "complete-registration"]
            },
            "description": "Step 4: Complete registration with user details and password. This automatically logs the user in."
          },
          "response": []
        },
        {
          "name": "5. Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has user ID\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.userId).to.exist;",
                  "});",
                  "",
                  "pm.test(\"Response has correct email\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.email).to.eql(pm.environment.get(\"testEmail\"));",
                  "});",
                  "",
                  "pm.test(\"Response has display name\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.displayName).to.exist;",
                  "});",
                  "",
                  "pm.test(\"Refresh token cookie is set\", function () {",
                  "    pm.expect(pm.cookies.has('refreshToken')).to.be.true;",
                  "});",
                  "",
                  "pm.test(\"Response time is less than 500ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Step 5: Login with email and password. Returns access token and sets refresh token cookie."
          },
          "response": []
        },
        {
          "name": "5b. Login - Invalid Credentials (Test)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 401 Unauthorized\", function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "",
                  "pm.test(\"Response has error details\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.title || jsonData.detail).to.exist;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"wrong@test.com\",\n  \"password\": \"wrongpassword\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "6. Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has message\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.exist;",
                  "});",
                  "",
                  "pm.test(\"New refresh token cookie is set\", function () {",
                  "    pm.expect(pm.cookies.has('refreshToken')).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh-token",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh-token"]
            },
            "description": "Step 6: Get a new access token using the refresh token from cookies. The refresh token cookie is automatically sent."
          },
          "response": []
        },
        {
          "name": "7. Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Cookies are cleared\", function () {",
                  "    pm.expect(pm.response.text()).to.be.empty;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "Step 7: Logout and revoke the refresh token. Cookies are automatically sent."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "1. Get My Profile (Requires Auth)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has user profile data\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.id).to.exist;",
                  "    pm.expect(jsonData.displayName).to.exist;",
                  "    pm.expect(jsonData.email).to.exist;",
                  "    pm.expect(jsonData.createdAt).to.exist;",
                  "});",
                  "",
                  "pm.test(\"Response has statistics\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.eventsCreated).to.exist;",
                  "    pm.expect(jsonData.eventsJoined).to.exist;",
                  "    pm.expect(jsonData.categoriesCount).to.exist;",
                  "});",
                  "",
                  "pm.test(\"Email matches test email\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.email).to.eql(pm.environment.get(\"testEmail\"));",
                  "});",
                  "",
                  "console.log(\"User Profile:\", pm.response.json());"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "me"]
            },
            "description": "Get the authenticated user's profile. Requires authentication (must be logged in)."
          },
          "response": []
        },
        {
          "name": "2. Get Profile Without Auth (Should Fail)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 401 Unauthorized\", function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "",
                  "console.log(\"Correctly rejected unauthorized request\");"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Clear cookies to simulate unauthenticated request",
                  "pm.cookies.clear();"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "me"]
            },
            "description": "Attempt to get profile without authentication. Should return 401 Unauthorized."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Events (TODO)",
      "item": []
    },
    {
      "name": "Categories (TODO)",
      "item": []
    }
  ]
}
