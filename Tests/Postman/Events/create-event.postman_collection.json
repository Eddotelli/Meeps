  "item": [
    {
      "name": "1. Create Event - Valid Data",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 201 Created\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Response has eventId\", function () {",
              "    const response = pm.response.json();",
              "    pm.expect(response).to.have.property('eventId');",
              "    pm.expect(response.eventId).to.be.a('number');",
              "    pm.environment.set('lastCreatedEventId', response.eventId);",
              "});",
              "",
              "pm.test(\"Response has title\", function () {",
              "    const response = pm.response.json();",
              "    pm.expect(response.title).to.equal(pm.variables.get('eventTitle'));",
              "});"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const timestamp = new Date().getTime();",
              "pm.variables.set('eventTitle', `Test Event ${timestamp}`);",
              "",
              "const tomorrow = new Date();",
              "tomorrow.setDate(tomorrow.getDate() + 1);",
              "tomorrow.setHours(18, 0, 0, 0);",
              "pm.variables.set('eventDateTime', tomorrow.toISOString());"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"{{eventTitle}}\",\n  \"description\": \"This is a test event created via Postman.\",\n  \"location\": \"Stockholm, Sweden\",\n  \"eventDateTime\": \"{{eventDateTime}}\",\n  \"categoryId\": 1,\n  \"minAttendance\": 5,\n  \"maxAttendance\": 20,\n  \"minAge\": 18,\n  \"maxAge\": 99,\n  \"genderRestriction\": 0\n}"
        },
        "url": {
