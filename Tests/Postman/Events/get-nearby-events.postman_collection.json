{
  "info": {
    "_postman_id": "get-nearby-events-tests",
    "name": "Get Nearby Events Tests",
    "description": "Test collection for GET /api/events/nearby endpoint",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get Nearby Events - Success",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response is an array\", function () {",
              "    const response = pm.response.json();",
              "    pm.expect(response).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/events/nearby?latitude=59.3293&longitude=18.0686&radiusKm=10",
          "host": ["{{baseUrl}}"],
          "path": ["api", "events", "nearby"],
          "query": [
            {
              "key": "latitude",
              "value": "59.3293"
            },
            {
              "key": "longitude",
              "value": "18.0686"
            },
            {
              "key": "radiusKm",
              "value": "10"
            }
          ]
        }
      },
      "response": []
    },
